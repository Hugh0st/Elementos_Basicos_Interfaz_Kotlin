<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

  <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="5. Elementos de Información"
      android:textSize="22sp"
      android:textStyle="bold"
      android:layout_marginBottom="8dp"/>

  <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Estos elementos (TextView, ImageView, ProgressBar) sirven para mostrar el estado de la app o datos al usuario sin que este tenga que modificarlos."
      android:layout_marginBottom="32dp"
      android:textAlignment="center"/>

  <ImageView
      android:id="@+id/ivMuestra"
      android:layout_width="120dp"
      android:layout_height="120dp"
      android:src="@android:drawable/ic_menu_gallery"
      android:layout_marginBottom="24dp"/>

  <ProgressBar
      android:id="@+id/progressBar"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:visibility="invisible"
      android:layout_marginBottom="16dp"/>

  <Button
      android:id="@+id/btnSimularCarga"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Simular Carga de Imagen" />

</LinearLayout>