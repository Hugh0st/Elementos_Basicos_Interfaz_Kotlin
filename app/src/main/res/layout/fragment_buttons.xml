<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloBotones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Botones (Buttons)"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvDescBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Los botones permiten al usuario realizar acciones al tocarlos. Existen variantes como botones con texto, botones con solo imagen (ImageButton) y botones flotantes (FAB)."
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnNormal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Botón Normal"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvDescBotones" />

    <ImageButton
        android:id="@+id/btnImagen"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:src="@android:drawable/ic_menu_camera"
        android:contentDescription="Botón de cámara"
        app:layout_constraintTop_toBottomOf="@id/btnNormal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_dialog_email"
        android:contentDescription="Enviar correo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>